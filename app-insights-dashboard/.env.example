# ── Dev server port ───────────────────────────────────────────────────────────
PORT=3000

# ── Backend API connection ────────────────────────────────────────────────────
REACT_APP_API_PROTOCOL=http
REACT_APP_API_HOSTNAME=localhost
REACT_APP_API_PORT=5000

# ── Dashboard display ─────────────────────────────────────────────────────────
REACT_APP_REGION_NAME=Your Region Name

# ── Misc ──────────────────────────────────────────────────────────────────────
BROWSER=none
REACT_APP_ENV=development
