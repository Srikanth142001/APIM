# ── Copy this to .env and fill in your values ─────────────────────────────────

# Auth
JWT_SECRET=change-this-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Ports
FRONTEND_PORT=3001
BACKEND_PORT=5001

# Frontend → Backend connection
# Set API_HOSTNAME to the IP/hostname the BROWSER uses to reach the backend
API_PROTOCOL=http
API_HOSTNAME=localhost
API_PORT=5001

# Optional: pre-seed a default Azure environment on first startup
# Leave blank to add environments via the UI after login
DEFAULT_ENV_NAME=
DEFAULT_APP_INSIGHTS_APP_ID=
DEFAULT_APP_INSIGHTS_API_KEY=
DEFAULT_SUBSCRIPTION_ID=
DEFAULT_RESOURCE_GROUP=
