# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-jwt-secret-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ── Azure Application Insights ────────────────────────────────────────────────
APP_INSIGHTS_APP_ID=your-app-insights-app-id
APP_INSIGHTS_API_KEY=your-app-insights-api-key

# ── Azure Subscription / Resource Group ───────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group-name

# ── AKS Cluster ───────────────────────────────────────────────────────────────
AKS_CLUSTER_NAME=your-aks-cluster-name

# ── MySQL Flexible Server ─────────────────────────────────────────────────────
MYSQL_SERVER_NAME=your-mysql-server-name

# ── Log Analytics (Azure Monitor) ─────────────────────────────────────────────
# Bearer token for Log Analytics API — refreshed via token script in Docker
LOG_ANALYTICS_AUTH_TOKEN=

# ── Telegram Notifications (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp Notifications (optional) ────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
