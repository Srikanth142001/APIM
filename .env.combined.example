# ═══════════════════════════════════════════════════════════════════════════════
# NexGen APIM — Combined Container Environment Variables
# Copy this file to .env.combined and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Port Configuration ─────────────────────────────────────────────────────────
APIM_PORT=8082

# ── Region Name ────────────────────────────────────────────────────────────────
REGION_NAME=SAN Region

# ── Azure App Insights (REQUIRED) ──────────────────────────────────────────────
APP_INSIGHTS_APP_ID=your-app-insights-app-id-here
APP_INSIGHTS_API_KEY=your-app-insights-api-key-here

# ── Azure Infrastructure (REQUIRED) ────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group-name
AKS_CLUSTER_NAME=your-aks-cluster-name
MYSQL_SERVER_NAME=your-mysql-server-name

# ── Log Analytics (REQUIRED) ───────────────────────────────────────────────────
LOG_ANALYTICS_WORKSPACE_ID=your-log-analytics-workspace-id
LOG_ANALYTICS_AUTH_TOKEN=your-log-analytics-bearer-token

# ── Authentication (REQUIRED) ──────────────────────────────────────────────────
JWT_SECRET=your-strong-random-secret-minimum-32-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# ── Telegram Notifications (OPTIONAL) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp Notifications (OPTIONAL) ──────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ── Feature Flags (OPTIONAL) ───────────────────────────────────────────────────
ENABLE_ML_ALERTS=true
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false
ENABLE_OUTAGE_DETECTION=true

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES:
# 1. Never commit the actual .env.combined file with real credentials
# 2. Generate a strong JWT_SECRET: openssl rand -base64 32
# 3. Get Log Analytics token from Azure Portal or use Azure CLI
# 4. Enable features as needed by setting to true/false
# ═══════════════════════════════════════════════════════════════════════════════
